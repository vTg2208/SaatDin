# Required
SUPABASE_DB_URL=
JWT_SECRET=replace-me

# Optional pool tuning
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# Existing app settings
EXPOSE_DEBUG_OTP=true

# Fraud scoring settings
FRAUD_SCORING_ENABLED=true
FRAUD_MODEL_PATH=backend/models/fraud/fraud_iforest_latest.joblib
FRAUD_ANOMALY_THRESHOLD=-0.05
FRAUD_FAIL_OPEN=true
FRAUD_METRICS_LOG_EVERY_N=25

# Optional external API keys
WAQI_API_KEY=
TOMTOM_API_KEY=
NEWS_API_KEY=

# Ambiguous fraud LLM fallback (LangGraph path)
FRAUD_LLM_FALLBACK_ENABLED=true
FRAUD_LLM_AMBIGUITY_MARGIN=0.02
FRAUD_LLM_TRIGGER_CONFIDENCE_MIN=0.35
FRAUD_LLM_TRIGGER_CONFIDENCE_MAX=0.75
FRAUD_LLM_PROVIDER_ORDER=groq,gemini
FRAUD_LLM_REQUEST_TIMEOUT_SECONDS=8
FRAUD_LLM_MAX_RETRIES_PER_PROVIDER=1
FRAUD_LLM_MAX_OUTPUT_TOKENS=350
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Co-claim cluster graph pipeline
CO_CLAIM_GRAPH_ENABLED=true
CO_CLAIM_GRAPH_SCHEDULE_HOURS=24
CO_CLAIM_GRAPH_LOOKBACK_DAYS=30
CO_CLAIM_GRAPH_TIME_BUCKET_MINUTES=10
CO_CLAIM_GRAPH_MIN_EDGE_SUPPORT=2
CO_CLAIM_GRAPH_RECENCY_HALF_LIFE_DAYS=7
CO_CLAIM_GRAPH_MIN_CLUSTER_MEMBERS=3
CO_CLAIM_GRAPH_MEDIUM_RISK_THRESHOLD=0.50
CO_CLAIM_GRAPH_HIGH_RISK_THRESHOLD=0.75
CO_CLAIM_GRAPH_MAX_CLUSTERS_PER_RUN=250

# Cell-tower cross-check signal
TOWER_VALIDATION_ENABLED=true
TOWER_SIGNAL_FRESHNESS_MINUTES=30
TOWER_SIGNAL_MAX_NEIGHBORS=8
TOWER_VALIDATION_SCORE_WEIGHT=0.12
TOWER_VALIDATION_ADJUSTMENT_CAP=0.12
TOWER_VALIDATION_DISTANCE_MATCH_KM=3
TOWER_VALIDATION_DISTANCE_MISMATCH_KM=12

# Motion cross-check signal (aggregate-only, privacy-safe)
MOTION_VALIDATION_ENABLED=true
MOTION_SIGNAL_FRESHNESS_MINUTES=30
MOTION_MIN_WINDOW_SECONDS=60
MOTION_MIN_SAMPLE_COUNT=12
MOTION_MIN_DISTANCE_METERS=25
MOTION_MAX_SPEED_MPS=33
MOTION_VALIDATION_SCORE_WEIGHT=0.10
MOTION_VALIDATION_ADJUSTMENT_CAP=0.10
MOTION_SIGNAL_RETENTION_DAYS=14
