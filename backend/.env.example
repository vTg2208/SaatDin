# ─────────────────────────────────────────────────────────────
#  SaatDin Backend — Environment Configuration
#  Copy this file to .env and fill in the values below.
# ─────────────────────────────────────────────────────────────

# ─── Database (Supabase PostgreSQL) ─────────────────────────
# Required runtime datasource. Example format:
# postgresql://postgres:<password>@<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# ─── Auth & Security ────────────────────────────────────────
# IMPORTANT: Replace with a strong random secret in production.
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-in-env
# Set to false in production to hide OTP codes from API responses.
EXPOSE_DEBUG_OTP=true

# ─── SMS Provider ────────────────────────────────────────────
# The send-otp endpoint currently stubs SMS delivery.
# To enable real SMS, implement _send_sms() in backend/app/api/auth.py
# and fill in your Twilio or MSG91 credentials below.
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_FROM_NUMBER=+1234567890

# ─── Weather Data (FREE — no key required) ───────────────────
# Open-Meteo is used for RainLock and HeatBlock triggers.
# No API key needed. Works out of the box.

# ─── Air Quality (WAQI) ─────────────────────────────────────
# Get a free token: https://aqicn.org/data-platform/token/
# Used for: AQI Guard trigger
WAQI_API_KEY=

# ─── Traffic (TomTom) ───────────────────────────────────────
# Free dev tier (2,500 calls/day): https://developer.tomtom.com/
# Used for: TrafficBlock trigger
TOMTOM_API_KEY=

# ─── News / Disruptions (NewsAPI) ────────────────────────────
# Free dev tier: https://newsapi.org/register
# Used for: ZoneLock automatic detection via keyword NLP
NEWS_API_KEY=

# ─── Fraud Detection — ML Model ─────────────────────────────
FRAUD_SCORING_ENABLED=true
# Relative path from project root. Already ships with the repo.
# FRAUD_MODEL_PATH=backend/models/fraud/fraud_iforest_latest.joblib
FRAUD_ANOMALY_THRESHOLD=-0.05

# ─── Fraud Detection — LLM Fallback ─────────────────────────
# Used ONLY for ambiguous fraud cases (Tiers 1+2 disagree).
# Provider order: groq is tried first, then gemini as fallback.
FRAUD_LLM_FALLBACK_ENABLED=true
FRAUD_LLM_PROVIDER_ORDER=groq,gemini

# Groq (free tier, no credit card): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Adversarial Defense ────────────────────────────────────
# Claim velocity spike: hold batch if >N claims in same zone within M minutes
CLAIM_VELOCITY_SPIKE_THRESHOLD=15
CLAIM_VELOCITY_SPIKE_WINDOW_MINUTES=10
# New account velocity: hold claims from accounts created <N days ago during red-alert
NEW_ACCOUNT_HOLD_DAYS=7

# ─── Payout Sandbox / Razorpay ──────────────────────────────
# Default mode is 'sandbox' (local simulation, no real transfers).
# To enable live payouts: set mode to 'live' and provide Razorpay keys.
# Dashboard: https://dashboard.razorpay.com/
PAYOUT_PROVIDER_MODE=sandbox
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Admin Dashboard ────────────────────────────────────────
# HTTP Basic credentials for the /admin/* endpoints
ADMIN_USERNAME=admin
ADMIN_PASSWORD=saatdin-local

# ─── Co-claim Graph Detection ───────────────────────────────
CO_CLAIM_GRAPH_ENABLED=true
CO_CLAIM_GRAPH_SCHEDULE_HOURS=24

# ─── Trigger Monitor ────────────────────────────────────────
TRIGGER_POLL_MINUTES=15
